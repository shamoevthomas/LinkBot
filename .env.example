# === Backend (Render) ===

# Supabase PostgreSQL - utiliser la connexion DIRECTE (port 5432, PAS le pooler 6543)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Securite - generer avec: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string

# CORS - URL du frontend Vercel (mettre a jour apres deploy)
CORS_ORIGINS=https://votre-app.vercel.app,http://localhost:5173

# Sentry (optionnel — si defini, les erreurs non gerees sont remontees)
SENTRY_DSN=

# Environnement
ENV=production
